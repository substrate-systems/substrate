{
  "name": "substrate",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "rm -rf .next && next dev --port 3000",
    "dev:next": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "hooks:install": "lefthook install",
    "migrate": "tsx scripts/migrate.ts",
    "migrate:dry": "tsx scripts/migrate.ts --dry",
    "test": "node --import tsx --experimental-test-module-mocks --test 'src/**/*.test.ts'",
    "openspec:list": "openspec list",
    "openspec:list:specs": "openspec list --specs",
    "openspec:validate": "openspec validate --all --strict --no-interactive",
    "openspec:validate:ci": "pwsh -NoProfile -File scripts/openspec_validate.ps1"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@neondatabase/serverless": "^1.0.2",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@opentelemetry/sdk-node": "^0.213.0",
    "@paddle/paddle-js": "^1.6.2",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.3.1",
    "argon2": "^0.44.0",
    "autoprefixer": "^10.4.23",
    "framer-motion": "^12.23.26",
    "next": "^16.1.1",
    "postcss": "^8.5.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@fission-ai/openspec": "~0.19.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@types/uuid": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^1.11.0",
    "prettier": "^3.7.4",
    "tidewave": "^0.6.0",
    "tsx": "^4.21.0"
  }
}
